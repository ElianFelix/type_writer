ENV=DEV
APPLICATION_NAME=type_writer
COMPOSE_PROJECT_NAME=type_writer

JWT_SIGNING_KEY=super_secret_key

API_PORT=1323
DB_PORT=6699

DB_NAME=type_writer_test
